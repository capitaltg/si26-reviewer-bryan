        "findings_gap_no_proposal": {
          "name": "findings_gap_no_proposal",
          "value": "(\"findings\".\"finding_kind\" <> 'gap') OR (\"findings\".\"proposal_verified\" IS NULL AND \"findings\".\"evidence_provenance\" IS NULL)"
        },
        "findings_observation_has_proposal": {
          "name": "findings_observation_has_proposal",
          "value": "(\"findings\".\"finding_kind\" <> 'observation') OR (\"findings\".\"proposal_verified\" IS NOT NULL)"
        },
        "findings_provenance_iff_proposal": {
          "name": "findings_provenance_iff_proposal",
          "value": "(\"findings\".\"evidence_provenance\" IS NOT NULL) = (\"findings\".\"proposal_verified\" IS TRUE)"
        },
        "findings_verified_requires_sides": {
          "name": "findings_verified_requires_sides",
          "value": "(\"findings\".\"verification\" <> 'verified') OR (\"findings\".\"solicitation_verified\" AND (\"findings\".\"finding_kind\" = 'gap' OR \"findings\".\"proposal_verified\"))"
        }
